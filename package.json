{
  "name": "codescan-ai",
  "version": "1.0.0",
  "description": "AI Code Reviewer with Groq + MongoDB + Docker + CI/CD",
  "main": "server.js",
  "scripts": {
    "start":  "node server.js",
    "dev":    "nodemon server.js",
    "test":   "echo \"No tests yet\" && exit 0",
    "lint":   "echo \"No linter configured\" && exit 0",
    "docker:up":   "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f app",
    "docker:build": "docker build -t codescan-ai ."
  },
  "dependencies": {
    "cors":     "^2.8.5",
    "dotenv":   "^16.3.1",
    "express":  "^4.18.2",
    "mongoose": "^8.0.3"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
