# ══════════════════════════════════════
#   CodeScan AI — .env.example
#   Copy this to .env and fill in values
#   NEVER commit .env to git!
# ══════════════════════════════════════

# MongoDB connection string
# Option A — Local MongoDB:    mongodb://localhost:27017/codescan
# Option B — Docker Compose:   mongodb://mongo:27017/codescan
# Option C — MongoDB Atlas:    mongodb+srv://user:pass@cluster.mongodb.net/codescan
MONGO_URI=mongodb://localhost:27017/codescan

# Express server port
PORT=3000

# Node environment
NODE_ENV=development
